FROM python:3.12-slim

ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1

WORKDIR /app

COPY requirements.txt requirements.inference.txt ./
RUN pip install --no-cache-dir --extra-index-url https://download.pytorch.org/whl/cu124 torch \
    && pip install --no-cache-dir -r requirements.inference.txt

COPY . .

CMD ["uvicorn", "services.inference_adapter.main:app", "--host", "0.0.0.0", "--port", "8050"]
