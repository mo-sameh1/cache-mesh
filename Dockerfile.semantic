FROM python:3.12-slim

ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1

WORKDIR /app

COPY requirements.semantic.txt .
RUN pip install --no-cache-dir --index-url https://download.pytorch.org/whl/cpu "torch==2.5.1+cpu"
RUN pip install --no-cache-dir -r requirements.semantic.txt

COPY . .

CMD ["uvicorn", "services.replica.main:app", "--host", "0.0.0.0", "--port", "8201"]
