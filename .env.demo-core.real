PROJECT_NAME=CacheMesh
LOG_LEVEL=INFO
ENVIRONMENT=development

CACHEMESH_ENV_FILE=.env.demo-core.real
APP_DOCKERFILE=Dockerfile.demo
INFERENCE_DOCKERFILE=Dockerfile.inference
COMPOSE_PROFILES=name-service,gateway,inference

GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8000
NAME_SERVICE_URL=http://host.docker.internal:8100
GATEWAY_REPLICA_TARGETS=replica-a=http://host.docker.internal:8201,replica-b=http://host.docker.internal:8202,replica-c=http://host.docker.internal:8203
GATEWAY_REPLICA_URLS=http://host.docker.internal:8201,http://host.docker.internal:8202,http://host.docker.internal:8203

NAME_SERVICE_HOST=0.0.0.0
NAME_SERVICE_PORT=8100

INFERENCE_ADAPTER_URL=http://host.docker.internal:8050
ADAPTER_HOST=0.0.0.0
ADAPTER_PORT=8050

INFERENCE_BACKEND=hf_transformers
INFERENCE_MODEL_ID=Qwen/Qwen2.5-7B-Instruct
INFERENCE_MAX_NEW_TOKENS=256
INFERENCE_TEMPERATURE=0.7
INFERENCE_TOP_P=0.9
INFERENCE_LOAD_IN_4BIT=true
INFERENCE_DEVICE=auto

REQUEST_TIMEOUT_SEC=30.0
HEARTBEAT_INTERVAL_SEC=1.0
SUSPECT_AFTER_MISSES=3
UNHEALTHY_AFTER_MISSES=5
FAULT_MODE=disabled
FAULT_DURATION_SEC=10
QDRANT_COLLECTION=cachemesh_entries
