PROJECT_NAME=CacheMesh
LOG_LEVEL=INFO
ENVIRONMENT=development

# Choose which services this machine should run.
# Examples:
#   COMPOSE_PROFILES=name-service,replica
#   COMPOSE_PROFILES=inference,replica
#   COMPOSE_PROFILES=gateway,replica
COMPOSE_PROFILES=replica

GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8000
NAME_SERVICE_URL=http://192.168.1.10:8100
GATEWAY_REPLICA_TARGETS=replica-a=http://192.168.1.10:8201,replica-b=http://192.168.1.11:8202,replica-c=http://192.168.1.12:8203
GATEWAY_REPLICA_URLS=http://192.168.1.10:8201,http://192.168.1.11:8202,http://192.168.1.12:8203

NAME_SERVICE_HOST=0.0.0.0
NAME_SERVICE_PORT=8100

REPLICA_ID=replica-a
REPLICA_HOST=0.0.0.0
REPLICA_PORT=8201
REPLICA_ADVERTISED_HOST=192.168.1.10
REPLICA_ADVERTISED_PORT=8201
REPLICA_PEER_TARGETS=replica-a=http://192.168.1.10:8201,replica-b=http://192.168.1.11:8202,replica-c=http://192.168.1.12:8203
INITIAL_TOKEN_REPLICA_ID=replica-a

# qdrant runs locally beside the replica on each machine.
QDRANT_URL=http://qdrant:6333
QDRANT_HOST_PORT=6333
QDRANT_COLLECTION=cachemesh_entries
# Hugging Face and sentence-transformer caches are persisted under .docker/
# so inference and replica model downloads survive container recreation.
# Set HF_TOKEN for authenticated Hugging Face downloads and higher rate limits.
SEMANTIC_EMBEDDING_MODEL_ID=sentence-transformers/all-MiniLM-L6-v2
SEMANTIC_VECTOR_SIZE=384
SEMANTIC_SCORE_THRESHOLD=0.72

REQUEST_TIMEOUT_SEC=2.0
INFERENCE_REQUEST_TIMEOUT_SEC=60.0
HEARTBEAT_INTERVAL_SEC=1.0
SUSPECT_AFTER_MISSES=3
UNHEALTHY_AFTER_MISSES=5

FAULT_MODE=disabled
FAULT_DURATION_SEC=10

INFERENCE_ADAPTER_URL=http://192.168.1.11:8050
ADAPTER_HOST=0.0.0.0
ADAPTER_PORT=8050
INFERENCE_BACKEND=stub
INFERENCE_MODEL_ID=Qwen/Qwen2.5-7B-Instruct
INFERENCE_MAX_NEW_TOKENS=256
INFERENCE_TEMPERATURE=0.7
INFERENCE_TOP_P=0.9
INFERENCE_LOAD_IN_4BIT=true
INFERENCE_DEVICE=auto
HF_TOKEN=<your_hugging_face_token_here>
